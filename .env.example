# =============================================================
# diamantes-grupo-participa — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================

# ── ClickUp ──────────────────────────────────────────────────
# Token pessoal ou de serviço do ClickUp.
# Alternativa legada: api/data/clickup-api-key.txt
GP_CLICKUP_API_KEY=

# Secret usado para verificar assinatura dos webhooks do ClickUp (HMAC-SHA256)
GP_CLICKUP_WEBHOOK_SECRET=

# ID do custom field "Cliente" no ClickUp (padrão: b25022f9-f6a7-44be-8b86-7454fe9fa770)
GP_CLICKUP_CLIENT_RELATION_FIELD_ID=

# ── Google Sheets Sync ────────────────────────────────────────
# URL do Google Apps Script que recebe o sync de dados
GP_SHEETS_SYNC_URL=
# Alias legado
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=

# Secret compartilhado para autenticar requisições ao Apps Script
GP_SHEETS_SYNC_SECRET=
# Alias legado
GOOGLE_APPS_SCRIPT_SECRET=

# ── E-mail ────────────────────────────────────────────────────
# Endereço remetente dos e-mails do sistema
GP_MAIL_FROM_EMAIL=nao-responda@diamantes.grupoparticipa.app.br

# Nome exibido no campo "De:" dos e-mails
GP_MAIL_FROM_NAME=Grupo Participa

# ── App ──────────────────────────────────────────────────────
# URL base da aplicação (sem barra final)
GP_APP_BASE_URL=https://diamantes.grupoparticipa.app.br

# ── Segurança ────────────────────────────────────────────────
# Define se o cookie de sessão deve exigir HTTPS (true em produção, false em dev HTTP).
# Default: true. Em desenvolvimento local com HTTP use GP_COOKIE_SECURE=false.
GP_COOKIE_SECURE=true

# Credenciais do admin principal — usadas APENAS pelo script api/scripts/setup-admin.php.
# Nunca deixe esses valores no .env em produção após a configuração.
# Execute: php api/scripts/setup-admin.php
GP_BOOTSTRAP_ADMIN_EMAIL=
GP_BOOTSTRAP_ADMIN_PASSWORD=

# ── Supabase (Fase 5) ─────────────────────────────────────────────────────────
# Driver de armazenamento: json (padrão) | supabase | dual
# - json      → flat-file JSON em api/storage/ (Fases 1-4, comportamento atual)
# - supabase  → PostgREST Supabase (requer GP_SUPABASE_URL + SERVICE_ROLE_KEY)
# - dual      → escreve em JSON (primário) + Supabase (secundário), lê do JSON.
#               Migração gradual sem downtime.
GP_STORAGE_DRIVER=json

# URL do projeto Supabase (sem barra final)
GP_SUPABASE_URL=https://gfynspfdkhtjrsboceka.supabase.co

# Service Role Key do Supabase (NUNCA exponha no frontend nem commite no repo)
# Encontre em: Supabase Dashboard → Project Settings → API → service_role
GP_SUPABASE_SERVICE_ROLE_KEY=

# Fonte de configuração dos portais: json (padrão) | supabase
# - json     → lê api/data/portals.json (fallback automático se Supabase falhar)
# - supabase → lê tabela public.clients via StorageDriver
GP_PORTALS_SOURCE=json

# Confirmar migração de dados (requerido para rodar migrate-all-to-supabase.php)
# Defina apenas ao executar o script de migração. Nunca deixe como yes em produção.
GP_MIGRATION_CONFIRM=
