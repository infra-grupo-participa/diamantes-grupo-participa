# operator/assets/.htaccess — JS e CSS do operator não devem ser cacheados
# agressivamente (espelho do portal/assets/.htaccess, evita Hostinger/LiteSpeed
# servir bundle antigo).
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
    <FilesMatch "\.(js|css)$">
        ExpiresActive On
        ExpiresDefault "access plus 0 seconds"
    </FilesMatch>
</IfModule>
