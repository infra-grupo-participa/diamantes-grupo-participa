# .deployignore — arquivos e pastas que NÃO sobem para a Hostinger
# Lido pelo workflow .github/workflows/deploy-*.yml no step "Assemble deploy artifact"
# Sintaxe: um padrão por linha; linhas começando com # são ignoradas

# Dependências de build / desenvolvimento
node_modules/
vendor/bin/

# Ambientes de teste e docs
tests/
docs/
tmp/

# CI/CD e controle de versão
.github/
.git/

# Arquivos de configuração exclusivos de dev
.gitignore
.gitleaksignore
biome.json
commitlint.config.js
deno.json
deno.lock
lefthook.yml
package.json
package-lock.json
composer.json
composer.lock
phpunit.xml.dist
playwright.config.js
vitest.config.js

# Documentação raiz
README.md
CONTRIBUTING.md
CLAUDE.md

# Templates e exemplos que não devem ir pra prod
.env.example
.deployignore
