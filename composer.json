{
    "name": "grupo-participa/diamantes",
    "description": "Portal de clientes Diamantes — Grupo Participa",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Diamantes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Diamantes\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "find . -name '*.php' -not -path './vendor/*' -exec php -l {} \\;"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
