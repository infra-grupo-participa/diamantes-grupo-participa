{
  "name": "diamantes-grupo-participa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portal Diamantes — Grupo Participa",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint assets/js admin/assets auth-guard.js --ext .js",
    "quality": "node scripts/quality-check.js",
    "quality:compare": "node scripts/compare-baseline.js",
    "quality:gate": "npm run quality && npm run quality:compare",
    "quality:update-baseline": "node scripts/update-baseline.js",
    "quality:pr-comment": "node scripts/render-pr-comment.js",
    "deploy:ftp": "node scripts/ftp-deploy.mjs",
    "deploy:ftp:dry": "node scripts/ftp-deploy.mjs --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.44.0",
    "@vitest/coverage-v8": "^3.2.0",
    "basic-ftp": "^6.0.1",
    "eslint": "^9.15.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "glob": "^11.0.0",
    "globals": "^15.12.0",
    "jscpd": "^4.0.5",
    "jsdom": "^29.1.1",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
