# Configuração Apache/LiteSpeed para diamantes.grupoparticipa.app.br
# Resolve:
#  - 403 ao acessar a raiz (servidor não enxergava index.html como índice)
#  - protege arquivos sensíveis de leitura direta

Options -Indexes

DirectoryIndex index.html

# Página de login fica na raiz; se vier "/" ou variantes vazias, garante index.html
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Acesso direto à raiz -> serve index.html (login)
    RewriteRule ^$ index.html [L]

    # /{slug}/ é a rota pública do cliente — redireciona para o dashboard.
    # Slug kebab-case; rotas internas excluídas abaixo. RLS valida o acesso.
    RewriteCond %{REQUEST_URI} !^/(api|admin|assets|portal|node_modules|tests|docs|tmp|tools|\.github)(/|$)
    RewriteRule ^([a-z][a-z0-9-]+)/?$ /portal/dashboard.html?slug=$1 [L,R=302]
</IfModule>

# Bloqueia acesso a configs locais e arquivos sensíveis
<FilesMatch "^(\.htaccess|\.htpasswd|\.DS_Store|php\.ini|php-local\.ini|.*\.example|.*\.md|HOSTINGER-DEPLOY\.md|GOOGLE-SHEETS-SYNC\.md)$">
    Require all denied
</FilesMatch>

# Bloqueia execução de scripts dentro de uploads/storage caso PHP escape para lá
<FilesMatch "\.(env|log|sqlite3?|jsonl)$">
    Require all denied
</FilesMatch>

# Cache estático — assets carregam mais rápido
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp "access plus 7 days"
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType text/css "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
</IfModule>

# Headers de segurança básicos
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # MEDIUM-2: Headers adicionais de segurança (Fase 1)
    # HSTS: força HTTPS por 1 ano em produção.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Permissions-Policy: desativa features não usadas.
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"

    # CSP — unsafe-inline necessário até Fase 4 extrair scripts inline.
    # cdn.jsdelivr.net: supabase-js CDN. *.supabase.co: Supabase Auth + REST.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.clickup.com https://*.supabase.co; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# LOW-1 defense-in-depth: bloqueia .json no webroot (além do .htaccess em api/storage/).
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>
